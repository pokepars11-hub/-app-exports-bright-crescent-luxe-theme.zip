                "settings": {
                  "html": "<section class=\"bct-hero\" style=\"background-image: linear-gradient(to bottom, rgba(2,16,36,0.58), rgba(2,16,36,0.2)), url('/wp-content/themes/bright-crescent-luxe/assets/images/hero.jpg');\">\n  <div class=\"bct-container bct-hero-inner\">\n    <p class=\"bct-section-tag\">BRIGHT CRESCENT TRADING EXPERIENCE</p>\n    <h1>Bright Crescent Trading Co LLC</h1>\n    <p class=\"bct-hero-sub\">Premium Trading in Appliances, Crystal Craft, and Precision Spare Parts</p>\n    <div class=\"bct-hero-cta-group\">\n      <a class=\"bct-btn bct-btn-gold\" href=\"/contact-us\">Contact Us</a>\n      <a class=\"bct-btn bct-btn-outline\" href=\"/appliances-products\">Explore Products</a>\n    </div>\n  </div>\n</section>\n<section class=\"bct-section bct-container\">\n  <p class=\"bct-section-tag\">Core Divisions</p>\n  <h2>Professional sourcing across appliances, crystal products, and spare parts.</h2>\n  <div class=\"bct-grid bct-grid-3\">\n    <article class=\"bct-card\"><div class=\"bct-card-media\"><img src=\"/wp-content/themes/bright-crescent-luxe/assets/images/home-appliances.jpg\" alt=\"Premium Appliances\"></div><div class=\"bct-card-content\"><h3>Premium Appliances</h3><p>Curated home and commercial appliances from trusted global manufacturers.</p><a class=\"bct-inline-link\" href=\"/appliances-products\">View Category</a></div></article>\n    <article class=\"bct-card\"><div class=\"bct-card-media\"><img src=\"/wp-content/themes/bright-crescent-luxe/assets/images/home-crystal.jpg\" alt=\"Crystal Products\"></div><div class=\"bct-card-content\"><h3>Crystal Products</h3><p>Elegant crystal pieces inspired by international design and craftsmanship.</p><a class=\"bct-inline-link\" href=\"/crystal-products\">View Category</a></div></article>\n    <article class=\"bct-card\"><div class=\"bct-card-media\"><img src=\"/wp-content/themes/bright-crescent-luxe/assets/images/home-spare-parts.jpg\" alt=\"Spare Parts\"></div><div class=\"bct-card-content\"><h3>Appliances Spare Parts</h3><p>Reliable AC, refrigerator, and washing-machine parts for technicians and businesses.</p><a class=\"bct-inline-link\" href=\"/appliances-spare-parts\">View Category</a></div></article>\n  </div>\n</section>\n<section class=\"bct-section bct-container bct-about-grid\">\n  <div><p class=\"bct-section-tag\">About Bright Crescent</p><h2>A trusted trading partner with premium standards.</h2><p>Bright Crescent Trading Co LLC serves retail and commercial clients across UAE with carefully selected appliances, elegant crystal products, and dependable spare parts solutions.</p></div>\n  <div class=\"bct-about-image-wrap\"><img src=\"/wp-content/themes/bright-crescent-luxe/assets/images/about.jpg\" alt=\"About Bright Crescent\"></div>\n</section>\n<section class=\"bct-section bct-container\"><div class=\"bct-cta-box\"><div><p class=\"bct-section-tag\">Partnership Opportunity</p><h2>Need premium product sourcing support?</h2><p>Connect with our team for product catalogs, pricing details, and partnership opportunities.</p></div><a class=\"bct-btn bct-btn-gold\" href=\"/contact-us\">Get in Touch</a></div></section>"
